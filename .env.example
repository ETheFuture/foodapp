# PostgreSQL (Vercel: Neon, Supabase, of Vercel Postgres – nooit SQLite in productie)
# Lokaal: zie docker-compose.yml → docker compose up -d
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/foodapp?schema=public"
AUTH_SECRET="minimaal-32-lange-willekeurige-string"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Vercel: Project → Settings → Environment Variables
# Zet minimaal DATABASE_URL en AUTH_SECRET op Production (en eventueel Preview).
# Eerste keer data: na deploy lokaal `DATABASE_URL=... npx prisma db seed` of vanaf machine met netwerk naar de DB.
