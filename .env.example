# PostgreSQL (Vercel: Neon, Supabase, Vercel Postgres)
# Lokaal: docker compose up -d
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/foodapp?schema=public"

# Niet verplicht voor de publieke site: alleen /api/health, /, /search werken zonder
NEXT_PUBLIC_APP_URL="https://jouw-app.vercel.app"

# Vercel build: `npm run build` draait migrate + seed (50 voorbeeldgerechten) + next build
# Zet DATABASE_URL in Vercel → Environment Variables (Production)
# Eerste deploy: seed vult 50 gerechten. Volgende deploys: seed slaat over als data bestaat.
